<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <!-- Viewport: esencial para responsividad en móvil -->
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
  <meta name="theme-color" content="#6c47ff" />
  <title>{{title}}</title>

  <!-- Fuentes Google -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet" />

  <!-- Íconos Remixicon -->
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet" />

  <!-- Estilos del sistema -->
  <link rel="stylesheet" href="/css/main.css" />
  <link rel="stylesheet" href="/css/sidebar.css" />
  <link rel="stylesheet" href="/css/dashboard.css" />
</head>
<body class="app-body">

  <!-- Sidebar lateral -->
  {{> sidebar}}

  <!-- Contenido principal -->
  <div class="main-wrapper" id="mainWrapper">

    <!-- Barra superior -->
    {{> topbar}}

    <!-- Mensajes flash -->
    <div class="flash-container">
      {{#if success_msg}}
        <div class="flash flash--success">
          <i class="ri-checkbox-circle-line"></i> {{success_msg}}
        </div>
      {{/if}}
      {{#if error_msg}}
        <div class="flash flash--error">
          <i class="ri-error-warning-line"></i> {{error_msg}}
        </div>
      {{/if}}
    </div>

    <!-- Contenido de cada página -->
    <main class="page-content">
      {{{body}}}
    </main>

    <!-- Footer -->
    <footer class="app-footer">
      <span>© {{currentYear}} CLOUDSOFT — Tu control, nuestro compromiso</span>
    </footer>

  </div>

  <!-- Scripts -->
  <script src="/js/sidebar.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
