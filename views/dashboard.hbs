     ============================================================ -->

<div class="dashboard-page">

  <!-- Mensaje de bienvenida -->
  <div class="dashboard-welcome">
    <div class="dashboard-welcome__text">
      <h2>¡Bienvenido, {{user.nombre}}! 👋</h2>
      <p>Selecciona una opción del menú lateral para comenzar.</p>
    </div>
    <!-- Ícono decorativo: cambiar la clase ri-XXX para otro ícono -->
    <div class="dashboard-welcome__icon">
      <i class="ri-cloud-line"></i>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════
       ZONA DE WIDGETS — Agregar aquí estadísticas,
       tarjetas resumen, gráficas, tablas rápidas, etc.
       Ejemplo de estructura de card:

       <div class="dash-card">
         <div class="dash-card__icon"><i class="ri-money-line"></i></div>
         <div class="dash-card__info">
           <span class="dash-card__label">Total Ingresos</span>
           <span class="dash-card__value">S/. 0.00</span>
         </div>
       </div>
  ══════════════════════════════════════════════════ -->

  <div class="dashboard-empty">
    <i class="ri-layout-grid-line"></i>
    <p>El panel principal está listo para ser configurado.</p>
    <small>Agrega widgets en <code>views/dashboard.hbs</code></small>
  </div>

</div>
